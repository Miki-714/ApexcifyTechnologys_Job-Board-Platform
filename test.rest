##############################################
# JOBS (Employer Actions)
##############################################

### Create a New Job (Requires Employer Token)
POST {{baseUrl}}/jobs
Authorization: Bearer {{employerToken}}
Content-Type: application/json

{
    "title": "Graphics Designer",
    "description": "We are seeking a talented Graphics Designer to create visually stunning designs for our clients. The ideal candidate will have a strong portfolio showcasing their creativity and proficiency in design software.",
    "requirements": ["Proficiency in design software", "Strong portfolio", "Excellent communication skills"],
    "salaryRange": "$80k - $120k",
    "location": "Remote",
    "jobType": "Remote"
}

##############################################
# JOBS (Public/Candidate Actions)
##############################################

### Get All Jobs (Public)
GET {{baseUrl}}/jobs

### Filter Jobs by Location & Keyword
GET {{baseUrl}}/jobs?location=Remote&keyword=Graphics Designer

##############################################
# APPLICATIONS
##############################################

### Apply for a Job (Candidate Only)
# Note: In REST Client, use 'multipart/form-data' for file uploads. 
# Replace <jobId> with a real ID from the Get Jobs request.
POST {{baseUrl}}/applications/apply/69f9d0f956362bd732099ddc
Authorization: Bearer {{candidateToken}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="resume"; filename="cv.pdf"
Content-Type: application/pdf

< C:/Users/MikiyasDereje/Desktop/cv.pdf
--boundary--

### View My Applications (Candidate Only)
GET {{baseUrl}}/applications/my-applications
Authorization: Bearer {{candidateToken}}

### View Applications for a Specific Job (Employer Only)
# Replace <jobId> with the ID of the job you created
GET {{baseUrl}}/applications/jobs/69f9d0f956362bd732099ddc/applications
Authorization: Bearer {{employerToken}}

### Update Application Status (Employer Only)
# Replace <appId> with the actual ID of an application
PATCH {{baseUrl}}/applications/69f9d18556362bd732099ddd/status
Authorization: Bearer {{employerToken}}
Content-Type: application/json

{
    "status": "Accepted"
}
