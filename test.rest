##############################################
# AUTHENTICATION
##############################################

### Register an Employer
POST {{baseUrl}}/register
Content-Type: application/json

{
    "name": "Apexcify HR",
    "email": "hr@apexcify.com",
    "password": "password123",
    "role": "Employer",
    "companyDescription": "Leading tech innovators."
}

### Register a Candidate
POST {{baseUrl}}/register
Content-Type: application/json

{
    "name": "John Doe",
    "email": "john@example.com",
    "password": "password123",
    "role": "Candidate"
}

##############################################
# JOBS (Employer Actions)
##############################################

### Create a New Job (Requires Employer Token)
POST {{baseUrl}}/jobs
Authorization: Bearer {{employerToken}}
Content-Type: application/json

{
    "title": "Senior Node.js Developer",
    "description": "Develop high-scale REST APIs.",
    "requirements": ["Node.js", "MongoDB", "Express"],
    "salaryRange": "$80k - $120k",
    "location": "Remote",
    "jobType": "Remote"
}

##############################################
# JOBS (Public/Candidate Actions)
##############################################

### Get All Jobs (Public)
GET {{baseUrl}}/jobs

### Filter Jobs by Location & Keyword
GET {{baseUrl}}/jobs?location=Remote&keyword=Node

##############################################
# APPLICATIONS
##############################################

### Apply for a Job (Candidate Only)
# Note: In REST Client, use 'multipart/form-data' for file uploads. 
# Replace <jobId> with a real ID from the Get Jobs request.
POST {{baseUrl}}/applications/apply/69e63b07b1515411554ccc9a
Authorization: Bearer {{candidateToken}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="resume"; filename="resume.pdf"
Content-Type: application/pdf

< ./resume.pdf
--boundary--

### View My Applications (Candidate Only)
GET {{baseUrl}}/applications/my-applications
Authorization: Bearer {{candidateToken}}

### View Applications for a Specific Job (Employer Only)
# Replace <jobId> with the ID of the job you created
GET {{baseUrl}}/applications/jobs/69e63b07b1515411554ccc9a/applications
Authorization: Bearer {{employerToken}}